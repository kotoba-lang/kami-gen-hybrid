{:paths ["src"]
 ;; Three `:local/root` deps per ADR-2607051130: `character` (deterministic
 ;; body/rig), `comfyui` (texture node-graph execution engine, renamed from
 ;; com-junkawasaki/comfyui-clj -- GitHub-transferred to kotoba-lang), `vrm`
 ;; (final .vrm assembly/export, renamed to org-vrmc-vrm). comfyui itself
 ;; depends on langchain (git dep, resolved transitively); the :dev alias
 ;; below overrides that to a local checkout for offline workspace
 ;; development, same convention as the "actor" repos (CLAUDE.md Actors
 ;; section).
 :deps {io.github.kotoba-lang/character
        {:local/root "../character"}
        io.github.kotoba-lang/comfyui
        {:local/root "../comfyui"}
        io.github.kotoba-lang/org-vrmc-vrm
        {:local/root "../org-vrmc-vrm"}}
 :aliases
 {:dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../langchain"}}}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
